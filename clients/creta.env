# Config de deploy do backend (api-creta) para o cliente Creta.
# Sem segredos aqui — segredos ficam só no Secret Manager do próprio projeto GCP do cliente.

CLIENT_SLUG=creta
GCP_PROJECT=creta-btg
FIREBASE_PROJECT=creta-btg-bd3a8
BQ_DATASET=dados_crus
GCS_BUCKET=creta-btg-pipeline
REGION=us-central1

# Origens autorizadas a chamar a API (CORS) — inclui o domínio novo e o antigo
# durante a migração.
ALLOWED_ORIGINS=https://creta.synciadesk.com.br,https://techumgit.github.io,http://localhost:8080,http://127.0.0.1:8080

# Nomes dos secrets no Secret Manager DESTE projeto (criar antes do primeiro deploy):
#   btg-client-id, btg-client-secret
