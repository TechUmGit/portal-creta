{
  "firestore": {
    "database": "(default)",
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".git/**",
      "**/.*",
      "**/node_modules/**",
      "api-creta/**",
      "job-carteira-recomendada/**",
      "job-noticias/**",
      "job-posicoes/**",
      "job-prioridades/**",
      "job-suitability/**",
      "webhook-btg/**",
      "config-api/**",
      "scripts/**",
      "clients/**",
      "*.pdf"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/config.js",
        "run": {
          "serviceId": "config-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "config-api",
          "region": "us-central1"
        }
      }
    ]
  }
}
